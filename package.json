{
  "name": "@dlunire/front-dlroute",
  "version": "2.2.1",
  "description": "Motor de rutas para UI: asocia URIs a componentes, funciones o cualquier recurso. Sin acoplarse a un framework de presentación ni a un backend específico.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "browser": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "node --test tests/*.test.mjs",
    "test:build": "pnpm run build && pnpm test"
  },
  "keywords": [
    "router",
    "routing",
    "dlroute",
    "frontend",
    "browser",
    "parser"
  ],
  "author": "David E. Luna M.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlunire/front-dlroute.git"
  },
  "bugs": {
    "url": "https://github.com/dlunire/front-dlroute/issues"
  },
  "homepage": "https://github.com/dlunire/front-dlroute#readme",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}